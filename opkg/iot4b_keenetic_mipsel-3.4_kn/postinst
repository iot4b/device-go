#!/bin/sh

# Constants
SERVICE_NAME="iot4b"
SERVICE_FILE="/opt/etc/init.d/S50iot4b"

# Start the service
echo ""
echo "Starting the IoT4B service..."

if [ ! -x "/opt/iot4b/iot4b" ]; then
    echo "Binary /opt/iot4b/iot4b not found or is not executable."
    exit 1
fi

killall "$SERVICE_NAME" 2>/dev/null

if [ -x "$SERVICE_FILE" ]; then
    "$SERVICE_FILE" start
    if [ $? -eq 0 ]; then
        echo "Service started successfully."
    else
        echo "Failed to start the service."
        exit 1
    fi
else
    echo "Service script $SERVICE_FILE not found or is not executable."
    exit 1
fi

echo ""
echo "Running IoT4B setup..."
(
  cd /opt/iot4b && ./iot4b setup --env iot4b
) || exit 1

echo ""
echo "Setup completed successfully."
exit 0
